generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

// Top-level org — every resource is scoped to an org (tenant)
model Organization {
  id           String    @id @default(uuid())
  name         String
  slug         String    @unique                // subdomain: "abc" → abc.chatcrm.org
  plan         String    @default("trial")      // trial|basic_10|basic_10_ai|pro_30|pro_30_ai|enterprise|enterprise_ai
  status       String    @default("active")     // active|suspended|expired
  maxZalo      Int       @default(2)  @map("max_zalo")
  aiEnabled    Boolean   @default(false) @map("ai_enabled")
  expiresAt    DateTime? @map("expires_at")     // null = không giới hạn thời gian
  logoUrl      String?   @map("logo_url")
  primaryColor String?   @map("primary_color")  // hex color cho branding
  contactName  String?   @map("contact_name")   // Tên người liên hệ
  contactPhone String?   @map("contact_phone")  // SĐT liên hệ
  notes        String?                          // Ghi chú khách hàng
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  teams            Team[]
  users            User[]
  zaloAccounts     ZaloAccount[]
  contacts         Contact[]
  conversations    Conversation[]
  appointments     Appointment[]
  activityLogs     ActivityLog[]
  dailyStats       DailyMessageStat[]
  settings         AppSetting[]
  duplicateGroups  DuplicateGroup[]
  savedReports     SavedReport[]
  integrations     Integration[]
  automationRules  AutomationRule[]
  messageTemplates MessageTemplate[]
  aiConfig         AiConfig?
  aiSuggestions    AiSuggestion[]
  campaignGroups   CampaignGroup[]
  campaigns        Campaign[]
  teamKnowledge    TeamKnowledge[]
  subscriptionLogs SubscriptionLog[]

  @@map("organizations")
}

// Team groups within an organization
model Team {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  name        String
  description String?  // Mô tả đội nhóm / ngành nghề
  createdAt   DateTime @default(now()) @map("created_at")

  org       Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  users     User[]          // backward compat
  members   TeamMember[]
  knowledge TeamKnowledge[]

  @@map("teams")
}

// N-N: User ↔ Team (1 nhân viên thuộc nhiều đội)
model TeamMember {
  id        String   @id @default(uuid())
  teamId    String   @map("team_id")
  userId    String   @map("user_id")
  role      String   @default("member") // member | lead
  createdAt DateTime @default(now()) @map("created_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_members")
}

// Kho tri thức của đội nhóm (nguồn RAG)
model TeamKnowledge {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  teamId      String   @map("team_id")
  title       String
  sourceType  String   @map("source_type") // "text" | "url" | "file"
  content     String   @db.Text // Nội dung gốc (sau khi parse)
  sourceUrl   String?  @map("source_url") // Nếu là URL
  fileUrl     String?  @map("file_url")   // Nếu là file
  status      String   @default("pending") // pending | indexing | indexed | failed
  chunkCount  Int      @default(0) @map("chunk_count")
  errorMsg    String?  @map("error_msg")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  org    Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  team   Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  chunks KnowledgeChunk[]

  @@index([teamId, status])
  @@map("team_knowledge")
}

// Các đoạn văn bản đã được embed thành vector
model KnowledgeChunk {
  id          String   @id @default(uuid())
  knowledgeId String   @map("knowledge_id")
  teamId      String   @map("team_id") // để filter nhanh
  orgId       String   @map("org_id")
  chunkIndex  Int      @map("chunk_index")
  content     String   @db.Text
  embedding   Unsupported("vector(768)")? // Gemini text-embedding-004
  createdAt   DateTime @default(now()) @map("created_at")

  knowledge TeamKnowledge @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([knowledgeId])
  @@map("knowledge_chunks")
}

// CRM user with role-based access
model User {
  id           String   @id @default(uuid())
  orgId        String   @map("org_id")
  teamId       String?  @map("team_id")
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  role         String   @default("member") // owner, admin, member
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  org              Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  team             Team?               @relation(fields: [teamId], references: [id])
  teamMemberships  TeamMember[]
  zaloAccounts     ZaloAccount[]
  zaloAccess       ZaloAccountAccess[]
  assignedContacts Contact[]           @relation("AssignedContacts")
  appointments     Appointment[]
  repliedMessages  Message[]           @relation("RepliedMessages")
  activityLogs     ActivityLog[]
  messageTemplates MessageTemplate[]

  @@map("users")
}

// Zalo account linked to a user (one user may own multiple Zalo accounts)
model ZaloAccount {
  id              String    @id @default(uuid())
  orgId           String    @map("org_id")
  ownerUserId     String    @map("owner_user_id")
  zaloUid         String?   @unique @map("zalo_uid")
  displayName     String?   @map("display_name")
  avatarUrl       String?   @map("avatar_url")
  phone           String?
  status          String    @default("disconnected") // connected, disconnected, qr_pending
  sessionData     Json?     @map("session_data")
  proxyUrl        String?   @map("proxy_url")
  lastConnectedAt DateTime? @map("last_connected_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  org            Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  owner          User                @relation(fields: [ownerUserId], references: [id])
  access         ZaloAccountAccess[]
  conversations  Conversation[]
  dailyStats     DailyMessageStat[]
  campaignQueues CampaignQueue[]

  @@map("zalo_accounts")
}

// ACL: which users can access which Zalo accounts
model ZaloAccountAccess {
  id            String   @id @default(uuid())
  zaloAccountId String   @map("zalo_account_id")
  userId        String   @map("user_id")
  permission    String   @default("read") // read, chat, admin
  createdAt     DateTime @default(now()) @map("created_at")

  zaloAccount ZaloAccount @relation(fields: [zaloAccountId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([zaloAccountId, userId])
  @@map("zalo_account_access")
}

// CRM contact record — generic pipeline with status field
model Contact {
  id               String    @id @default(uuid())
  orgId            String    @map("org_id")
  zaloUid          String?   @map("zalo_uid")
  phone            String?
  email            String?   @map("email")
  fullName         String?   @map("full_name")
  crmName          String?   @map("crm_name")
  avatarUrl        String?   @map("avatar_url")
  source           String?   // FB, TT, GT, CN, etc.
  sourceDate       DateTime? @map("source_date")
  firstContactDate DateTime? @map("first_contact_date")
  status           String?   @default("new") // new/contacted/interested/converted/lost
  nextAppointment  DateTime? @map("next_appointment")
  assignedUserId   String?   @map("assigned_user_id")
  notes            String?
  tags             Json      @default("[]")
  metadata         Json      @default("{}")
  leadScore        Int       @default(0) @map("lead_score")
  lastActivity     DateTime? @map("last_activity")
  mergedInto       String?   @map("merged_into")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  org               Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  assignedUser      User?        @relation("AssignedContacts", fields: [assignedUserId], references: [id])
  mergedIntoContact Contact?     @relation("ContactMerge", fields: [mergedInto], references: [id])
  mergedFrom        Contact[]    @relation("ContactMerge")
  conversations     Conversation[]
  appointments      Appointment[]
  campaignQueues    CampaignQueue[]

  @@index([orgId, phone])
  @@index([orgId, zaloUid])
  @@index([orgId, mergedInto])
  @@map("contacts")
}

// A chat thread between a Zalo account and a contact (or group)
model Conversation {
  id               String    @id @default(uuid())
  orgId            String    @map("org_id")
  zaloAccountId    String    @map("zalo_account_id")
  contactId        String?   @map("contact_id")
  threadType       String    @default("user") // user, group
  externalThreadId String?   @map("external_thread_id")
  lastMessageAt    DateTime? @map("last_message_at")
  unreadCount      Int       @default(0) @map("unread_count")
  isReplied        Boolean   @default(true) @map("is_replied")
  tab              String    @default("main") @map("tab") // main, other
  createdAt        DateTime  @default(now()) @map("created_at")

  org           Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  zaloAccount   ZaloAccount   @relation(fields: [zaloAccountId], references: [id], onDelete: Cascade)
  contact       Contact?      @relation(fields: [contactId], references: [id])
  messages      Message[]
  aiSuggestions AiSuggestion[]

  @@unique([zaloAccountId, externalThreadId])
  @@index([orgId, zaloAccountId, isReplied, lastMessageAt])
  @@index([orgId, zaloAccountId, lastMessageAt])
  @@index([orgId, tab, lastMessageAt])
  @@map("conversations")
}

// Individual message within a conversation
model Message {
  id              String    @id @default(uuid())
  conversationId  String    @map("conversation_id")
  zaloMsgId       String?   @map("zalo_msg_id")
  senderType      String    @map("sender_type") // self, contact
  senderUid       String?   @map("sender_uid")
  senderName      String?   @map("sender_name")
  content         String?
  contentType     String    @default("text") @map("content_type") // text, image, file, sticker, voice, video, link
  attachments     Json      @default("[]")
  reactions       Json      @default("[]")
  isDeleted       Boolean   @default(false) @map("is_deleted")
  deletedAt       DateTime? @map("deleted_at")
  sentAt          DateTime  @map("sent_at")
  repliedByUserId String?   @map("replied_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  repliedBy    User?        @relation("RepliedMessages", fields: [repliedByUserId], references: [id])

  @@unique([conversationId, zaloMsgId])
  @@map("messages")
}

// Appointment scheduled for a contact
model Appointment {
  id              String   @id @default(uuid())
  orgId           String   @map("org_id")
  contactId       String   @map("contact_id")
  assignedUserId  String?  @map("assigned_user_id")
  appointmentDate DateTime @map("appointment_date")
  appointmentTime String?  @map("appointment_time")
  type            String?
  status          String   @default("scheduled") // scheduled, completed, cancelled, no_show
  notes           String?
  reminderSent    Boolean  @default(false) @map("reminder_sent")
  createdAt       DateTime @default(now()) @map("created_at")

  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  assignedUser User?        @relation(fields: [assignedUserId], references: [id])

  @@map("appointments")
}

// Audit trail for user actions
model ActivityLog {
  id         String   @id @default(uuid())
  orgId      String   @map("org_id")
  userId     String?  @map("user_id")
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  details    Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User?        @relation(fields: [userId], references: [id])

  @@map("activity_logs")
}

// Daily messaging statistics per user per Zalo account
model DailyMessageStat {
  id                String   @id @default(uuid())
  orgId             String   @map("org_id")
  userId            String   @map("user_id")
  zaloAccountId     String   @map("zalo_account_id")
  statDate          DateTime @map("stat_date") @db.Date
  messagesSent      Int      @default(0) @map("messages_sent")
  messagesReceived  Int      @default(0) @map("messages_received")
  messagesUnread    Int      @default(0) @map("messages_unread")
  messagesUnreplied Int      @default(0) @map("messages_unreplied")
  avgResponseTime   Int?     @map("avg_response_time_seconds")

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  zaloAccount ZaloAccount  @relation(fields: [zaloAccountId], references: [id], onDelete: Cascade)

  @@unique([userId, zaloAccountId, statDate])
  @@map("daily_message_stats")
}

// External service integration (Google Sheets, Telegram, Facebook, Zapier)
model Integration {
  id         String    @id @default(uuid())
  orgId      String    @map("org_id")
  type       String    // google_sheets | telegram | facebook | zapier
  name       String    @default("")
  config     Json      @default("{}") // credentials + settings
  enabled    Boolean   @default(true)
  lastSyncAt DateTime? @map("last_sync_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  syncLogs SyncLog[]

  @@map("integrations")
}

// Sync execution log for integrations
model SyncLog {
  id            String   @id @default(uuid())
  integrationId String   @map("integration_id")
  direction     String   // import | export
  recordCount   Int      @default(0) @map("record_count")
  status        String   // success | partial | failed
  errorMessage  String?  @map("error_message")
  createdAt     DateTime @default(now()) @map("created_at")

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@map("sync_logs")
}

// Encrypted or plain key-value settings per org
model AppSetting {
  id             String   @id @default(uuid())
  orgId          String   @map("org_id")
  settingKey     String   @map("setting_key")
  valuePlain     String?  @map("value_plain")
  valueEncrypted Bytes?   @map("value_encrypted")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, settingKey])
  @@map("app_settings")
}

// Groups of potentially duplicate contacts detected by the intelligence cron
model DuplicateGroup {
  id         String   @id @default(uuid())
  orgId      String   @map("org_id")
  contactIds String[] @map("contact_ids")
  matchType  String   @map("match_type") // phone, zalo_uid, name
  confidence Float    @default(1.0)
  resolved   Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, resolved])
  @@map("duplicate_groups")
}

// Saved analytics report configuration
model SavedReport {
  id        String   @id @default(uuid())
  orgId     String   @map("org_id")
  name      String
  type      String   // conversion_funnel, team_performance, response_time, custom
  config    Json     @default("{}")
  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("saved_reports")
}

model AutomationRule {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  name        String
  description String?
  trigger     String
  conditions  Json     @default("[]")
  actions     Json     @default("[]")
  enabled     Boolean  @default(true)
  priority    Int      @default(0)
  runCount    Int      @default(0) @map("run_count")
  lastRunAt   DateTime? @map("last_run_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, trigger, enabled, priority])
  @@map("automation_rules")
}

model MessageTemplate {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  ownerUserId String?  @map("owner_user_id")
  name        String
  content     String
  category    String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  owner User?        @relation(fields: [ownerUserId], references: [id])

  @@index([orgId, ownerUserId])
  @@index([orgId, category])
  @@map("message_templates")
}

model AiConfig {
  id        String   @id @default(uuid())
  orgId     String   @unique @map("org_id")
  provider  String   @default("anthropic")
  model     String   @default("claude-sonnet-4-6")
  maxDaily  Int      @default(500) @map("max_daily")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("ai_configs")
}

model AiSuggestion {
  id             String    @id @default(uuid())
  orgId          String    @map("org_id")
  conversationId String    @map("conversation_id")
  messageId      String?   @map("message_id")
  type           String
  content        String
  confidence     Float
  accepted       Boolean   @default(false)
  createdAt      DateTime  @default(now()) @map("created_at")

  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
  @@index([conversationId, createdAt])
  @@index([orgId, type, createdAt])
  @@map("ai_suggestions")
}

// ─── Campaign Module ────────────────────────────────────────────────────────

// Nhóm khách hàng chiến dịch
model CampaignGroup {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  name        String
  description String?
  // "all" | "exclude" | "manual"
  mode        String   @default("manual")
  // IDs khách hàng được chọn (mode=manual) hoặc bị loại trừ (mode=exclude)
  contactIds  Json     @default("[]") @map("contact_ids")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  campaigns Campaign[]

  @@index([orgId])
  @@map("campaign_groups")
}

// Chiến dịch gửi tin nhắn
model Campaign {
  id             String    @id @default(uuid())
  orgId          String    @map("org_id")
  groupId        String    @map("group_id")
  title          String
  // JSON array: [{type:"text",value:"..."},{type:"image",base64:"..."}]
  content        Json      @default("[]")
  // "once" | "daily" | "weekly" | "monthly"
  scheduleType   String    @default("once") @map("schedule_type")
  // Giờ gửi "HH:mm"
  scheduleTime   String?   @map("schedule_time")
  // Ngày cụ thể ISO (once) hoặc ngày trong tuần/tháng
  scheduleValue  String?   @map("schedule_value")
  isRecurring    Boolean   @default(false) @map("is_recurring")
  // "draft" | "active" | "paused" | "completed"
  status         String    @default("draft")
  lastRunAt      DateTime? @map("last_run_at")
  nextRunAt      DateTime? @map("next_run_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  org        Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  group      CampaignGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  queueItems CampaignQueue[]

  @@index([orgId, status])
  @@index([orgId, nextRunAt])
  @@map("campaigns")
}

// Hàng đợi gửi tin nhắn từ chiến dịch
model CampaignQueue {
  id            String    @id @default(uuid())
  campaignId    String    @map("campaign_id")
  contactId     String    @map("contact_id")
  zaloAccountId String    @map("zalo_account_id")
  // "pending" | "sending" | "sent" | "failed"
  status        String    @default("pending")
  sentAt        DateTime? @map("sent_at")
  error         String?
  chunkIndex    Int       @default(0) @map("chunk_index")
  createdAt     DateTime  @default(now()) @map("created_at")

  campaign    Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact     Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  zaloAccount ZaloAccount @relation(fields: [zaloAccountId], references: [id], onDelete: Cascade)

  @@index([campaignId, status])
  @@index([campaignId, chunkIndex])
  @@map("campaign_queue")
}

// ── Multi-Tenant SaaS Models ────────────────────────────────────────────────

// Platform super admin — manages all tenants (separate from org users)
model PlatformAdmin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  role         String   @default("superadmin") // superadmin | support
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("platform_admins")
}

// Subscription history log per tenant
model SubscriptionLog {
  id        String   @id @default(uuid())
  orgId     String   @map("org_id")
  action    String   // created | upgraded | downgraded | renewed | suspended | activated | expired
  plan      String   // plan at the time of action
  note      String?  // admin note
  createdBy String?  @map("created_by") // platform admin id
  createdAt DateTime @default(now()) @map("created_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
  @@map("subscription_logs")
}
