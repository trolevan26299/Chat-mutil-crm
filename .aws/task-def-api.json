{
  "family": "chatcrm-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "chatcrm-app",
      "image": "ACCOUNT_ID.dkr.ecr.ap-southeast-1.amazonaws.com/chatcrm-app:latest",
      "essential": true,
      "portMappings": [
        { "containerPort": 3000, "protocol": "tcp" }
      ],
      "environment": [
        { "name": "NODE_ENV",     "value": "production" },
        { "name": "PORT",         "value": "3000" },
        { "name": "TZ",           "value": "Asia/Ho_Chi_Minh" },
        { "name": "WORKER_MODE",  "value": "false" }
      ],
      "secrets": [
        { "name": "DATABASE_URL",        "valueFrom": "arn:aws:secretsmanager:ap-southeast-1:ACCOUNT_ID:secret:chatcrm/prod:DATABASE_URL::" },
        { "name": "REDIS_URL",           "valueFrom": "arn:aws:secretsmanager:ap-southeast-1:ACCOUNT_ID:secret:chatcrm/prod:REDIS_URL::" },
        { "name": "JWT_SECRET",          "valueFrom": "arn:aws:secretsmanager:ap-southeast-1:ACCOUNT_ID:secret:chatcrm/prod:JWT_SECRET::" },
        { "name": "ENCRYPTION_KEY",      "valueFrom": "arn:aws:secretsmanager:ap-southeast-1:ACCOUNT_ID:secret:chatcrm/prod:ENCRYPTION_KEY::" },
        { "name": "APP_URL",             "valueFrom": "arn:aws:secretsmanager:ap-southeast-1:ACCOUNT_ID:secret:chatcrm/prod:APP_URL::" },
        { "name": "OPENROUTER_API_KEY",  "valueFrom": "arn:aws:secretsmanager:ap-southeast-1:ACCOUNT_ID:secret:chatcrm/prod:OPENROUTER_API_KEY::" },
        { "name": "GOOGLE_AI_API_KEY",   "valueFrom": "arn:aws:secretsmanager:ap-southeast-1:ACCOUNT_ID:secret:chatcrm/prod:GOOGLE_AI_API_KEY::" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group":         "/ecs/chatcrm-api",
          "awslogs-region":        "ap-southeast-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command":     ["CMD-SHELL", "wget -qO- http://localhost:3000/health || exit 1"],
        "interval":    30,
        "timeout":     10,
        "retries":     3,
        "startPeriod": 60
      },
      "stopTimeout": 30,
      "ulimits": [
        { "name": "nofile", "softLimit": 65536, "hardLimit": 65536 }
      ]
    }
  ]
}
